@model Itransition_Course_Project.ViewModels.SearchResultsViewModel

@{
    ViewData["Title"] = "Search Results";
    int totalMatches = Model.MatchedInventories.Count + Model.MatchedItems.Count;
}

<div class="container mt-4">
    <div class="mb-4">
        <h1 class="h3 text-secondary mb-1">Global Search Engine</h1>
        <p class="text-muted">Found <span class="fw-bold text-primary">@totalMatches</span> results matching: <span class="badge bg-light text-dark border font-monospace fs-6">"@Model.SearchQuery"</span></p>
    </div>

    @if (totalMatches == 0)
    {
        <div class="text-center py-5 border rounded bg-light shadow-sm my-4">
            <i class="bi bi-search-heart fs-1 text-muted d-block mb-3"></i>
            <h3 class="h5 text-secondary">No Matches Located</h3>
            <p class="text-muted mb-0">Double-check your spelling or look for different keywords across templates or metadata items.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @if (Model.MatchedInventories.Any())
            {
                <div class="col-12">
                    <h5 class="text-secondary fw-bold border-bottom pb-2 mb-3">
                        <i class="bi bi-folder-fill text-warning me-2"></i> Matching Collections (@Model.MatchedInventories.Count)
                    </h5>
                    <div class="list-group shadow-sm rounded border">
                        @foreach (var inv in Model.MatchedInventories)
                        {
                            <a href="/Inventory/Details/@inv.Id" class="list-group-item list-group-item-action p-3 d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="fw-bold text-dark fs-5">@inv.Title</div>
                                    <small class="text-muted text-truncate-1 d-block mb-1" style="max-width: 600px;">@inv.Description</small>
                                    <span class="badge bg-secondary-subtle text-secondary border small text-uppercase fw-bold" style="font-size: 0.7rem;">@inv.Category</span>
                                </div>
                                <div class="text-end small text-muted">
                                    <div>Managed by</div>
                                    <span class="fw-bold text-secondary">@inv.Creator?.UserName</span>
                                </div>
                            </a>
                        }
                    </div>
                </div>
            }

            @if (Model.MatchedItems.Any())
            {
                <div class="col-12 mt-4">
                    <h5 class="text-secondary fw-bold border-bottom pb-2 mb-3">
                        <i class="bi bi-cpu-fill text-success me-2"></i> Matching Assets Ledger Items (@Model.MatchedItems.Count)
                    </h5>
                    <div class="table-responsive border rounded shadow-sm">
                        <table class="table table-hover align-middle mb-0 small">
                            <thead class="table-light border-bottom text-uppercase fw-bold text-muted" style="font-size: 0.8rem;">
                                <tr>
                                    <th class="ps-4">Asset ID</th>
                                    <th>Parent Collection Template</th>
                                    <th>Custom Field Matches Summary</th>
                                    <th class="pe-4 text-end">Committed By</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.MatchedItems)
                                {
                                    <tr style="cursor: pointer;" onclick="window.location.href='/Inventory/Details/@item.InventoryId'">
                                        <td class="ps-4 fw-bold text-primary font-monospace">@item.CustomId</td>
                                        <td class="fw-bold text-secondary">@item.Inventory?.Title</td>
                                        <td>
                                            <span class="text-muted italic small">
                                                @string.Join(" | ", new[] { item.CustomString1_Value, item.CustomString2_Value, item.CustomString3_Value }.Where(s => !string.IsNullOrEmpty(s)).Take(2))
                                            </span>
                                        </td>
                                        <td class="pe-4 text-end text-muted">@item.CreatedBy?.UserName</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .text-truncate-1 {
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;  
        overflow: hidden;
    }
</style>