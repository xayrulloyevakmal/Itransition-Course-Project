@model Itransition_Course_Project.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Create Account";
}

<div class="container mt-5" style="max-width: 500px;">
    <div class="card shadow border rounded">
        <div class="card-header py-3 text-center">
            <h3 class="h5 mb-0 fw-bold">Join AssetTrack</h3>
        </div>
        <div class="card-body p-4">
            <form asp-controller="Account" asp-action="Register" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="mb-3">
                    <label class="form-label small fw-bold text-muted text-uppercase">Username</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-person-fill"></i></span>
                        <input asp-for="Username" class="form-control" placeholder="Choose a unique handle" required />
                    </div>
                    <span asp-validation-for="Username" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label small fw-bold text-muted text-uppercase">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-envelope-fill"></i></span>
                        <input asp-for="Email" type="email" class="form-control" placeholder="name@example.com" required />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label small fw-bold text-muted text-uppercase">Password</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                        <input asp-for="Password" type="password" class="form-control" placeholder="Minimum 6 characters" required />
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label small fw-bold text-muted text-uppercase">Confirm Password</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-shield-lock-fill"></i></span>
                        <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Repeat your password" required />
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2 shadow-sm fw-bold">Sign Up</button>
            </form>

            <hr class="my-4" />
            <p class="text-center text-muted small mb-3">Or sign up with</p>
            <div class="d-flex gap-2">
                <form asp-controller="Account" asp-action="ExternalLogin" method="post" class="flex-fill">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="provider" value="Google" />
                    <button type="submit" class="btn btn-outline-danger w-100">
                        <i class="bi bi-google"></i> Google
                    </button>
                </form>
                <form asp-controller="Account" asp-action="ExternalLogin" method="post" class="flex-fill">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="provider" value="Facebook" />
                    <button type="submit" class="btn btn-outline-primary w-100">
                        <i class="bi bi-facebook"></i> Facebook
                    </button>
                </form>
            </div>
        </div>
        <div class="card-footer text-center py-3 small">
            Already have an account? <a asp-controller="Account" asp-action="Login" class="text-decoration-none fw-bold">Sign In here</a>
        </div>
    </div>
</div>