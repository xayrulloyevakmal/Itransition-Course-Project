<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AssetTrack</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
<header>
    <nav class="navbar navbar-expand-lg border-bottom shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Inventory" asp-action="Index">
                <i class="bi bi-box-seam-fill text-primary me-1"></i> AssetTrack
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Inventory" asp-action="Index">
                            <i class="bi bi-grid-fill"></i> Dashboard
                        </a>
                    </li>
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="Users">
                                <i class="bi bi-shield-lock"></i> Admin
                            </a>
                        </li>
                    }
                </ul>

                <!-- Search bar -->
                <form class="d-flex me-3" asp-controller="Home" asp-action="Search" method="get" role="search">
                    <div class="input-group input-group-sm">
                        <input type="search" name="query" class="form-control" placeholder="Search inventories & items..." aria-label="Search" style="min-width: 220px;" />
                        <button class="btn btn-outline-primary" type="submit">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>

                <div class="d-flex align-items-center gap-2">
                    <!-- Theme toggle -->
                    <button class="btn btn-sm btn-outline-secondary" id="themeToggleBtn" type="button" title="Toggle theme">
                        <i class="bi bi-moon-fill" id="themeIcon"></i>
                    </button>

                    <!-- Language toggle -->
                    <button class="btn btn-sm btn-outline-secondary" id="langToggleBtn" type="button" title="Toggle language">
                        <span id="langLabel">EN</span>
                    </button>

                    <partial name="_LoginPartial" />
                </div>
            </div>
        </div>
    </nav>
</header>

<div class="container">
    <main role="main" class="pb-3 mt-3">
        @RenderBody()
    </main>
</div>

<footer class="border-top py-3 mt-5 text-center text-muted small">
    &copy; @DateTime.Now.Year AssetTrack — Inventory Management System
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js"></script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>