@model IEnumerable<Itransition_Course_Project.Models.Inventory>

@{
    ViewData["Title"] = "Templates Dashboard";
}

<div class="container mt-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center border-bottom pb-3 mb-4 gap-3">
        <div>
            <h1 class="h2 text-secondary mb-1">Collections Dashboard</h1>
            <p class="text-muted mb-0">Browse public asset schemas or manage your custom inventory tracking deployments.</p>
        </div>
        <div>
            @if (User.Identity is { IsAuthenticated: true })
            {
                <a href="/Inventory/Create" class="btn btn-primary shadow-sm fw-bold px-4 py-2">
                    <i class="bi bi-folder-plus"></i> New Template Configuration
                </a>
            }
            else
            {
                <a href="/Account/Login" class="btn btn-outline-primary shadow-sm px-4 py-2">
                    <i class="bi bi-box-arrow-in-right"></i> Sign In to Build Template
                </a>
            }
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 border rounded bg-light shadow-sm">
            <i class="bi bi-folder-x fs-1 text-muted d-block mb-3"></i>
            <h3 class="h5 text-secondary">No Inventory Templates Available</h3>
            <p class="text-muted mb-0">Be the first to build an asset structural configuration system tracking matrix!</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4 mb-5">
            @foreach (var inventory in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border hover-shadow style-card transition-all" style="cursor: pointer;" onclick="window.location.href='/Inventory/Details/@inventory.Id'">
                        <div class="card-body p-4 d-flex flex-column">
                            
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="badge bg-secondary-subtle text-secondary border px-2.5 py-1 small text-uppercase fw-bold">
                                    <i class="bi bi-tag-fill me-1"></i> @inventory.Category
                                </span>
                                <span class="text-muted small font-monospace bg-light border px-2 py-0.5 rounded">
                                    @inventory.CustomIdFormat
                                </span>
                            </div>

                            <h4 class="h5 text-dark fw-bold mb-2">@inventory.Title</h4>
                            
                            <p class="text-muted small flex-grow-1 mb-4 text-truncate-2">
                                @inventory.Description
                            </p>

                            <div class="border-top pt-3 mt-auto d-flex align-items-center justify-content-between text-muted small">
                                <div>
                                    <i class="bi bi-person-circle text-primary me-1"></i>
                                    Manager: <span class="fw-bold text-secondary">@inventory.Creator?.UserName</span>
                                </div>
                                <div class="text-end text-primary fw-bold">
                                    View Assets <i class="bi bi-arrow-right-short"></i>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .transition-all {
        transition: all 0.2s ease-in-out;
    }
    .hover-shadow:hover {
        transform: translateY(-4px);
        box-shadow: 0 .5rem 1.5rem rgba(0,0,0,.08)!important;
        border-color: #cbd5e1 !important;
    }
    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;  
        overflow: hidden;
    }
</style>